reconstruct_general_absolute_flux <- function(Dataset) {
  
  # --- 1. PHYSICAL PRE-PROCESSING (URT FILTERING) ---
  # Only taxa exceeding the 10x Poisson Noise Floor are analyzed.
  P_raw <- as.matrix(Dataset)
  n_s <- nrow(P_raw)
  sample_minima <- apply(P_raw, 1, function(x) min(x[x > 0]))
  
  # Policy: Reliability requires a tenfold safety margin over the detection limit.
  is_reliable <- sweep(P_raw, 1, sample_minima * 10, ">=")
  valid_taxa <- colnames(P_raw)[apply(is_reliable, 2, all)]

  # Mathematical stability requires at least 4 samples to define a physical structure.
  if(n_s < 4) {
    stop("CRITICAL ERROR: Insufficient samples (< 4). Physical structure cannot be defined.")
  }

  # Mathematical Constraint: Physical reconstruction requires at least 5 dimensions.
  if(length(valid_taxa) < 5) {
    stop("CRITICAL ERROR: Insufficient reliable dimensions (< 5 URT).")
  }
  P_urt <- P_raw[, valid_taxa]
  
  # --- 2. COMPONENT LOG-VARIANCE ANALYSIS ---
  # Analyzing variance in the log-transformed compositional space.
  L <- log(P_urt)
  v_observed <- apply(L, 2, var) # Observed variance (Vx^2)
  
  # --- 3. RESIDUAL STRAIN DECODING ("Zure" Analysis) ---
  # Pearson's Approximation: Vx^2 ≈ Vw^2 + Vt^2 - 2*cov(w, t)
  # The 'Residual Strain' represents the structural distortion 
  # forced upon each component by the closure constraint.
  
  # Calculate geometric information distances (Information Wrinkles)
  info_dist_mat <- as.matrix(dist(t(L)))
  
  # Strain Potential: Quantifying how much each component is 
  # compressed by the total volume's fluctuation.
  strain_potential <- rowMeans(info_dist_mat)
  zure_coeff <- mean(strain_potential)
  
  # --- 4. INVERSE TOTAL FLUX ESTIMATION (General Solution) ---
  # Identifying the 'Point of Minimum Tension' to isolate Vt^2.
  # This reconstructs the latent absolute scale without a specific anchor.
  strain_ratio <- min(strain_potential) / max(strain_potential)
  estimated_Vt_sq <- min(v_observed) * (1 - strain_ratio)
  estimated_Vt <- sqrt(abs(estimated_Vt_sq))
  
  # --- 5. ABSOLUTE VARIATION RECONSTRUCTION ---
  # Recovering Vw (Absolute Coefficient of Variation) for all components.
  # Vw^2 ≈ Vx^2 - Vt^2
  vw_reconstructed <- sqrt(pmax(0, v_observed - estimated_Vt_sq))

  # 6. Export to CSV
  write.csv(P_urt, "Reliable_Input_Data.csv")

  # --- FINAL SYSTEM REPORT ---
  cat("\n==========================================================\n")
  cat("      ITAGAKI GENERAL SOLUTION: ABSOLUTE RECONSTRUCTION    \n")
  cat("==========================================================\n")
  cat(sprintf("Estimated System Total Flux (Vt) : %.6f\n", estimated_Vt))
  cat(sprintf("Residual Strain Coeff (Zure)     : %.6f\n", zure_coeff))
  cat(sprintf("Analyzed Dimensions (URT)        : %d\n", length(valid_taxa)))
  cat("----------------------------------------------------------\n")
  cat("Status: General Solution applied via Residual Dynamics.\n")
  cat("==========================================================\n")
  
 return(list(
    Summary = data.frame(
      Component = valid_taxa,
      Reconstruct_CV = vw_reconstructed,
      Compositional_CV = sqrt(v_observed),
      Strain_Impact = strain_potential
    ),
    P_urt = P_urt
  ))
}

